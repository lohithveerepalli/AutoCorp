# ─────────────────────────────────────────────────────────────
# AutoCorp Environment Configuration
# Copy to .env and fill in the keys you need.
# ─────────────────────────────────────────────────────────────

# ── LLM Providers ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
# Local Ollama (no key required when running ollama serve)
OLLAMA_BASE_URL=http://localhost:11434

# Default models (overridden by `autocorp setup` interactive config)
BRAIN_MODEL=claude-sonnet-4-5
OPERATOR_MODEL=gpt-4o
MARKETER_MODEL=gpt-4o
ACCOUNTANT_MODEL=gpt-4o

# ── GitHub (Brain deploys code) ───────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=
GITHUB_ORG=   # optional; creates under personal account if empty

# ── Vercel ───────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_ACCESS_TOKEN=
SUPABASE_ORG_ID=

# ── Domain Registrars (Operator) ─────────────────────────────
# At least one is recommended for real purchases
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_CLIENT_IP=
NAMECHEAP_SANDBOX=true

PORKBUN_API_KEY=
PORKBUN_SECRET_KEY=

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ── Email / Google Workspace (optional) ──────────────────────
GOOGLE_WORKSPACE_ADMIN_EMAIL=
GOOGLE_SERVICE_ACCOUNT_JSON=   # path to service account JSON
# Fallback mock email provider used when Google is not configured

# ── Stripe (Accountant) ──────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── Social (Marketer) — strong mocks + approval by default ───
# Real OAuth/API keys only used when AUTO_APPROVE_SOCIAL=true
# and human has completed platform OAuth setup.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
LINKEDIN_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
AUTO_APPROVE_SOCIAL=false

# ── AutoCorp Runtime ─────────────────────────────────────────
AUTOCORP_DB_PATH=./data/autocorp.db
AUTOCORP_DATA_DIR=./data
AUTOCORP_REQUIRE_HUMAN_APPROVAL=true
AUTOCORP_LOG_LEVEL=INFO
# Monthly API cost alert threshold (USD)
AUTOCORP_BUDGET_ALERT_USD=50
